# Google Vertex AI (used by LiteLLM proxy for LLM and mem0 for embeddings)
# Paste the full service account JSON as a single line (no newlines)
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
VERTEX_PROJECT_ID=coworking-aggegator
VERTEX_LOCATION=europe-west3

# Google AI (used by Graphiti via OpenAI-compatible endpoint, and Cognee embeddings)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic (used by Cognee LLM)
ANTHROPIC_API_KEY=your_anthropic_key_here

# PostgreSQL
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon2025
POSTGRES_DB=memory_benchmark

# Neo4j
NEO4J_AUTH=neo4j/hackathon2025

# Runner identification
RUNNER_NAME=tomas

# Host IP (LAN)
HOST_IP=192.168.0.44
