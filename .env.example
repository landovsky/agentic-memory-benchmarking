# LLM Configuration — use Anthropic first, Gemini as fallback
ANTHROPIC_API_KEY=your_anthropic_key_here

# Gemini via Vertex AI (fallback)
GOOGLE_CLOUD_PROJECT=your_gcp_project
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# PostgreSQL
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon2025
POSTGRES_DB=memory_benchmark

# Neo4j
NEO4J_AUTH=neo4j/hackathon2025

# Runner identification
RUNNER_NAME=your_name_here

# Host IP (for MCP configs)
HOST_IP=192.168.1.100
